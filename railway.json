{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "FritApi/Dockerfile"
  },
  "deploy": {
    "preDeployCommand": [
      "dotnet FritApi.dll --migrate"
    ],
    "healthcheckPath": "/health",
    "healthcheckTimeout": 100
  }
}
