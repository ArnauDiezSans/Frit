<file path="FritWeb/src/app/features/juegos/juegos-page.component.html">
<section class="dashboard-page">
  <header class="dashboard-header">
    <div>
      <p class="eyebrow">Frit</p>
      <h1>Jocs</h1>
      <p class="subtitle">
        Gestiona la teva ludoteca i registra jocs nous abans de crear partides.
      </p>
    </div>

    <div class="header-actions">
      <button type="button" class="secondary-button" routerLink="/app/partidas">
        Veure partides
      </button>
      <button type="button" class="primary-button" (click)="abrirModal()">
        Nou joc
      </button>
      <button type="button" class="ghost-button" (click)="logout()">Sortir</button>
    </div>
  </header>

  <section class="content-card" *ngIf="loading()">
    <p>Carregant jocs i usuaris...</p>
  </section>

  <section class="content-card error-card" *ngIf="error()">
    <p>{{ error() }}</p>
    <button type="button" class="primary-button" (click)="cargarDatos()">
      Tornar-ho a provar
    </button>
  </section>

  <section class="content-card" *ngIf="!loading() && !error()">
    <div class="section-heading">
      <div>
        <h2>Llista de jocs</h2>
        <p>La teva col·lecció disponible per a futures partides.</p>
      </div>

      <div class="toolbar">
        <button
          type="button"
          class="toolbar-chip"
          [class.toolbar-chip-active]="showFilters()"
          (click)="toggleFilters()"
        >
          <span>Filtres</span>
        </button>

        <div class="columns-wrapper" (click)="$event.stopPropagation()">
          <button
            type="button"
            class="toolbar-chip"
            [class.toolbar-chip-active]="showColumnsPanel()"
            (click)="toggleColumnsPanel($event)"
          >
            <span>Columnes</span>
          </button>

          <div class="columns-panel" *ngIf="showColumnsPanel()">
            <div class="columns-panel-header">
              <span>Columnes visibles</span>
              <button
                type="button"
                class="columns-close"
                (click)="showColumnsPanel.set(false)"
              >
                ×
              </button>
            </div>

            <label class="columns-option">
              <input
                type="checkbox"
                [checked]="allColumnsSelected()"
                (change)="selectAllColumns()"
              />
              <span>Seleccionar totes</span>
            </label>

            <hr />

            <label class="columns-option">
              <input
                type="checkbox"
                [checked]="visibleColumns().nombre"
                (change)="toggleColumn('nombre')"
              />
              <span>Nom</span>
            </label>

            <label class="columns-option">
              <input
                type="checkbox"
                [checked]="visibleColumns().numeroJugadoresMin"
                (change)="toggleColumn('numeroJugadoresMin')"
              />
              <span>Jugadors mín.</span>
            </label>

            <label class="columns-option">
              <input
                type="checkbox"
                [checked]="visibleColumns().numeroJugadoresMax"
                (change)="toggleColumn('numeroJugadoresMax')"
              />
              <span>Jugadors màx.</span>
            </label>

            <label class="columns-option">
              <input
                type="checkbox"
                [checked]="visibleColumns().propietario"
                (change)="toggleColumn('propietario')"
              />
              <span>Propietari</span>
            </label>

            <label class="columns-option">
              <input
                type="checkbox"
                [checked]="visibleColumns().tipo"
                (change)="toggleColumn('tipo')"
              />
              <span>Tipus</span>
            </label>

            <label class="columns-option">
              <input
                type="checkbox"
                [checked]="visibleColumns().pvp"
                (change)="toggleColumn('pvp')"
              />
              <span>PVP</span>
            </label>

            <label class="columns-option">
              <input
                type="checkbox"
                [checked]="visibleColumns().juegoBase"
                (change)="toggleColumn('juegoBase')"
              />
              <span>Joc base</span>
            </label>

            <div class="columns-actions">
              <button type="button" class="secondary-button" (click)="resetTableState()">
                Restablir
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th *ngIf="visibleColumns().nombre" (click)="sortBy('nombre')">
              Nom {{ getSortIndicator('nombre') }}
            </th>
            <th *ngIf="visibleColumns().numeroJugadoresMin" (click)="sortBy('numeroJugadoresMin')">
              Jugadors mín. {{ getSortIndicator('numeroJugadoresMin') }}
            </th>
            <th *ngIf="visibleColumns().numeroJugadoresMax" (click)="sortBy('numeroJugadoresMax')">
              Jugadors màx. {{ getSortIndicator('numeroJugadoresMax') }}
            </th>
            <th *ngIf="visibleColumns().propietario" (click)="sortBy('propietario')">
              Propietari {{ getSortIndicator('propietario') }}
            </th>
            <th *ngIf="visibleColumns().tipo" (click)="sortBy('tipo')">
              Tipus {{ getSortIndicator('tipo') }}
            </th>
            <th *ngIf="visibleColumns().pvp" (click)="sortBy('pvp')">
              PVP {{ getSortIndicator('pvp') }}
            </th>
            <th *ngIf="visibleColumns().juegoBase" (click)="sortBy('juegoBase')">
              Joc base {{ getSortIndicator('juegoBase') }}
            </th>
          </tr>

          <tr *ngIf="showFilters()">
            <th *ngIf="visibleColumns().nombre">
              <input
                type="text"
                class="filter-input"
                placeholder="Filtra..."
                [value]="filters().nombre"
                (input)="updateFilter('nombre', $any($event.target).value)"
              />
            </th>

            <th *ngIf="visibleColumns().numeroJugadoresMin">
              <input
                type="number"
                class="filter-input"
                placeholder="Filtra..."
                [value]="filters().numeroJugadoresMin"
                (input)="updateFilter('numeroJugadoresMin', $any($event.target).value)"
              />
            </th>

            <th *ngIf="visibleColumns().numeroJugadoresMax">
              <input
                type="number"
                class="filter-input"
                placeholder="Filtra..."
                [value]="filters().numeroJugadoresMax"
                (input)="updateFilter('numeroJugadoresMax', $any($event.target).value)"
              />
            </th>

            <th *ngIf="visibleColumns().propietario">
              <input
                type="text"
                class="filter-input"
                placeholder="Filtra..."
                [value]="filters().propietario"
                (input)="updateFilter('propietario', $any($event.target).value)"
              />
            </th>

            <th *ngIf="visibleColumns().tipo">
              <input
                type="text"
                class="filter-input"
                placeholder="Filtra..."
                [value]="filters().tipo"
                (input)="updateFilter('tipo', $any($event.target).value)"
              />
            </th>

            <th *ngIf="visibleColumns().pvp">
              <input
                type="number"
                class="filter-input"
                placeholder="Filtra..."
                [value]="filters().pvp"
                (input)="updateFilter('pvp', $any($event.target).value)"
              />
            </th>

            <th *ngIf="visibleColumns().juegoBase">
              <input
                type="text"
                class="filter-input"
                placeholder="Filtra..."
                [value]="filters().juegoBase"
                (input)="updateFilter('juegoBase', $any($event.target).value)"
              />
            </th>
          </tr>
        </thead>

        <tbody>
          <tr *ngFor="let juego of juegosFiltradosOrdenados(); trackBy: trackByJuegoId">
            <td *ngIf="visibleColumns().nombre">{{ juego.nombre }}</td>
            <td *ngIf="visibleColumns().numeroJugadoresMin">{{ juego.numeroJugadoresMin }}</td>
            <td *ngIf="visibleColumns().numeroJugadoresMax">{{ juego.numeroJugadoresMax }}</td>
            <td *ngIf="visibleColumns().propietario">{{ getNombrePropietario(juego.propietarioId) }}</td>
            <td *ngIf="visibleColumns().tipo">{{ juego.tipo || '-' }}</td>
            <td *ngIf="visibleColumns().pvp">{{ juego.pvp ?? '-' }}</td>
            <td *ngIf="visibleColumns().juegoBase">{{ getNombreJuegoBase(juego.juegoBaseId) }}</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="empty-state" *ngIf="juegos().length > 0 && juegosFiltradosOrdenados().length === 0">
      <h3>Cap joc coincideix amb els filtres</h3>
      <p>Prova d’ajustar o esborrar algun filtre de les columnes.</p>
    </div>

    <div class="empty-state" *ngIf="juegos().length === 0">
      <h3>Encara no hi ha jocs registrats</h3>
      <p>Afegeix el primer joc de la teva col·lecció.</p>
    </div>
  </section>

  <div class="modal-backdrop" *ngIf="modalOpen()" (click)="cerrarModal()">
    <section class="modal-card" (click)="$event.stopPropagation()">
      <div class="modal-header">
        <div>
          <h2>Nou joc</h2>
          <p>Completa les dades del joc o carrega-les des de BoardGameGeek.</p>
        </div>

        <button type="button" class="ghost-button" (click)="cerrarModal()">
          Tancar
        </button>
      </div>

      <form [formGroup]="form" (ngSubmit)="submit()" class="game-form">
        <div class="form-grid">
          <label class="form-field bgg-row">
            <span>BGG ID</span>
            <div class="bgg-inline">
              <input type="number" formControlName="bggId" min="1" />
              <button
                type="button"
                class="secondary-button"
                (click)="cargarDesdeBgg()"
                [disabled]="bggLoading()"
              >
                {{ bggLoading() ? 'Carregant...' : 'Carregar' }}
              </button>
            </div>
          </label>

          <label class="form-field">
            <span>Nom</span>
            <input type="text" formControlName="nombre" />
            <small class="field-error" *ngIf="nombre.touched && nombre.invalid">
              El nom és obligatori.
            </small>
          </label>

          <label class="form-field">
            <span>Dificultat BGG</span>
            <input type="number" step="0.01" formControlName="dificultadBgg" />
          </label>

          <label class="form-field">
            <span>Jugadors mínims</span>
            <input type="number" formControlName="numeroJugadoresMin" min="1" />
          </label>

          <label class="form-field">
            <span>Jugadors màxims</span>
            <input type="number" formControlName="numeroJugadoresMax" min="1" />
          </label>

          <label class="form-field">
            <span>PVP</span>
            <input type="number" step="0.01" formControlName="pvp" min="0" />
          </label>

          <label class="form-field autocomplete-field">
            <span>Propietari</span>
            <input
              type="text"
              formControlName="propietarioSearch"
              autocomplete="off"
              (click)="$event.stopPropagation()"
            />

            <div
              class="autocomplete-panel"
              *ngIf="showPropietarioOptions()"
              (click)="$event.stopPropagation()"
            >
              <button
                type="button"
                class="autocomplete-option"
                *ngFor="let usuario of filteredUsuarios()"
                (click)="seleccionarPropietario(usuario)"
              >
                {{ usuario.nombre }}
              </button>

              <button
                type="button"
                class="autocomplete-option"
                *ngIf="form.controls.propietarioId.value"
                (click)="limpiarPropietario()"
              >
                Sense propietari
              </button>

              <p
                class="autocomplete-empty"
                *ngIf="filteredUsuarios().length === 0 && !form.controls.propietarioId.value"
              >
                No s’han trobat propietaris.
              </p>
            </div>
          </label>

          <label class="form-field">
            <span>Tipus</span>
            <input type="text" formControlName="tipo" />
          </label>

          <label class="form-field">
            <span>Data d’adquisició</span>
            <input type="date" formControlName="fechaAdquisicion" />
          </label>

          <label class="form-field autocomplete-field">
            <span>Joc base</span>
            <input
              type="text"
              formControlName="juegoBaseSearch"
              autocomplete="off"
              (click)="$event.stopPropagation()"
            />

            <div
              class="autocomplete-panel"
              *ngIf="showJuegoBaseOptions()"
              (click)="$event.stopPropagation()"
            >
              <button
                type="button"
                class="autocomplete-option"
                *ngFor="let juego of filteredJuegosBase()"
                (click)="seleccionarJuegoBase(juego)"
              >
                {{ juego.nombre }}
              </button>

              <button
                type="button"
                class="autocomplete-option"
                *ngIf="form.controls.juegoBaseId.value"
                (click)="limpiarJuegoBase()"
              >
                Sense joc base
              </button>

              <p
                class="autocomplete-empty"
                *ngIf="filteredJuegosBase().length === 0 && !form.controls.juegoBaseId.value"
              >
                No s’han trobat jocs base.
              </p>
            </div>
          </label>
        </div>

        <small class="field-error" *ngIf="form.errors?.['minGreaterThanMax']">
          El mínim de jugadors no pot ser més gran que el màxim.
        </small>

        <p class="error" *ngIf="formError()">{{ formError() }}</p>
        <p class="success" *ngIf="success()">{{ success() }}</p>

        <div class="modal-actions">
          <button type="button" class="secondary-button" (click)="cerrarModal()">
            Cancel·lar
          </button>

          <button type="submit" class="primary-button" [disabled]="saving()">
            {{ saving() ? 'Desant...' : 'Desar joc' }}
          </button>
        </div>
      </form>
    </section>
  </div>
</section>
</file>

