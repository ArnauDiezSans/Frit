<section class="dashboard-page">
  <header class="dashboard-header">
    <div>
      <p class="eyebrow">Frit</p>
      <h1>Jocs</h1>
      <p class="subtitle">Gestiona la teva ludoteca i registra jocs nous abans de crear partides.</p>
    </div>

    <div class="header-actions">
      <button type="button" class="secondary-button" routerLink="/app/partidas">Veure partides</button>
      <button type="button" class="ghost-button" (click)="logout()">Sortir</button>
    </div>
  </header>

  <section class="content-card" *ngIf="loading()">
    <p>Carregant jocs i usuaris...</p>
  </section>

  <section class="content-card error-card" *ngIf="error()">
    <p>{{ error() }}</p>
    <button type="button" class="primary-button" (click)="cargarDatos()">Tornar-ho a provar</button>
  </section>

  <section class="content-card" *ngIf="!loading() && !error()">
    <div class="section-heading">
      <div>
        <h2>Llista de jocs</h2>
        <p>La teva col·lecció disponible per a futures partides.</p>
      </div>

      <button type="button" class="primary-button" (click)="abrirModal()">Nou joc</button>
    </div>

    <div class="empty-state" *ngIf="juegos().length === 0">
      <h3>Encara no hi ha jocs registrats</h3>
      <p>Comença creant el teu primer joc des del botó Nou joc.</p>
    </div>

    <div class="table-wrapper" *ngIf="juegos().length > 0">
      <table>
        <thead>
          <tr>
            <th>Nom</th>
            <th>Jugadors</th>
            <th>Propietari</th>
            <th>Tipus</th>
            <th>PVP</th>
          </tr>
        </thead>
        <tbody>
          <tr *ngFor="let juego of juegos(); trackBy: trackByJuegoId">
            <td>{{ juego.nombre }}</td>
            <td>{{ juego.numeroJugadoresMin }} - {{ juego.numeroJugadoresMax }}</td>
            <td>{{ getNombrePropietario(juego.propietarioId) }}</td>
            <td>{{ juego.tipo }}</td>
            <td>{{ juego.pvp ?? '-' }}</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <div class="modal-backdrop" *ngIf="modalOpen()" (click)="cerrarModal()">
    <section
      class="modal-card"
      role="dialog"
      aria-modal="true"
      aria-labelledby="nuevo-juego-title"
      (click)="$event.stopPropagation()"
    >
      <div class="modal-header">
        <div>
          <h2 id="nuevo-juego-title">Nou joc</h2>
          <p>Escriu el propietari i selecciona una opció de la llista filtrada.</p>
        </div>

        <button
          type="button"
          class="ghost-icon-button"
          aria-label="Tancar formulari"
          (click)="cerrarModal()"
        >
          ×
        </button>
      </div>

      <form class="game-form" [formGroup]="form" (ngSubmit)="submit()">
        <div class="form-grid">
          <label>
            <span>Nom <span class="required-mark">*</span></span>
            <input type="text" formControlName="nombre" />
            <small class="field-error" *ngIf="nombre.touched && nombre.invalid">
              El nom és obligatori.
            </small>
          </label>

          <label class="autocomplete-field">
            <span>Propietari <span class="required-mark">*</span></span>
            <input
              type="text"
              formControlName="propietarioSearch"
              (focus)="showPropietarioOptions.set(true)"
              autocomplete="off"
            />

            <div class="autocomplete-panel" *ngIf="showPropietarioOptions()">
              <button
                type="button"
                class="autocomplete-option"
                *ngFor="let usuario of filteredUsuarios()"
                (click)="seleccionarPropietario(usuario)"
              >
                {{ usuario.nombre }}
              </button>

              <p class="autocomplete-empty" *ngIf="filteredUsuarios().length === 0">
                No s'han trobat propietaris.
              </p>
            </div>

            <small class="field-error" *ngIf="propietarioId.touched && propietarioId.invalid">
              Has de seleccionar un propietari vàlid.
            </small>
          </label>

          <label>
            <span>Jugadors mínims <span class="required-mark">*</span></span>
            <input type="number" formControlName="numeroJugadoresMin" min="1" />
          </label>

          <label>
            <span>Jugadors màxims <span class="required-mark">*</span></span>
            <input type="number" formControlName="numeroJugadoresMax" min="1" />
          </label>

          <label>
            <span>Tipus</span>
            <input type="text" formControlName="tipo" />
          </label>

          <label>
            <span>BGG ID</span>
            <input type="number" formControlName="bggId" min="1" />
          </label>

          <label>
            <span>Dificultat BGG</span>
            <input type="number" formControlName="dificultadBgg" step="0.01" min="0" />
          </label>

          <label>
            <span>PVP</span>
            <input type="number" formControlName="pvp" step="0.01" min="0" />
          </label>

          <label>
            <span>Data d'adquisició</span>
            <input type="date" formControlName="fechaAdquisicion" />
          </label>

          <label>
            <span>ID joc base</span>
            <input type="number" formControlName="juegoBaseId" min="1" />
          </label>
        </div>

        <small class="field-error" *ngIf="form.errors?.['minGreaterThanMax']">
          El mínim de jugadors no pot ser més gran que el màxim.
        </small>

        <p class="error" *ngIf="formError()">{{ formError() }}</p>
        <p class="success" *ngIf="success()">{{ success() }}</p>

        <div class="modal-actions">
          <button type="button" class="secondary-button" (click)="cerrarModal()">Cancel·lar</button>
          <button type="submit" class="primary-button" [disabled]="saving()">
            {{ saving() ? 'Desant...' : 'Desar joc' }}
          </button>
        </div>
      </form>
    </section>
  </div>
</section>
